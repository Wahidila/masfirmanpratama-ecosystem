# ============================================================
# PRODUCTION ENV TEMPLATE — STORE (masfirmanpratama.com)
# ============================================================
# Copy ke `.env` di server produksi, lalu ISI nilai placeholder.
# JANGAN commit file .env yang sudah terisi secret.
# Generate APP_KEY dengan: php artisan key:generate
# ============================================================

APP_NAME="MasFirmanPratama"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://masfirmanpratama.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Asia/Jakarta

# --- Logging (production: harian, level warning) ---
LOG_CHANNEL=daily
LOG_LEVEL=warning

# --- Database (MySQL produksi) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=store_db
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# --- Session / Cache / Queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=false
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Mail (isi SMTP produksi) ---
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@masfirmanpratama.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Webhook ke Affiliate (HMAC-SHA256) ---
# URL endpoint receiver di app affiliate
AFFILIATE_WEBHOOK_URL=https://affiliate.masfirmanpratama.com/webhooks/store
# WAJIB sama persis dengan STORE_WEBHOOK_SECRET di app affiliate.
# Generate: php -r "echo bin2hex(random_bytes(32));"
AFFILIATE_WEBHOOK_SECRET=CHANGE_ME_SHARED_SECRET
AFFILIATE_WEBHOOK_TIMEOUT=5
AFFILIATE_WEBHOOK_RETRIES=3

# --- WhatsApp XSender ---
XSENDER_ENDPOINT=https://xsender.id/id/send-message
XSENDER_API_KEY=CHANGE_ME
XSENDER_SENDER=CHANGE_ME

VITE_APP_NAME="${APP_NAME}"
