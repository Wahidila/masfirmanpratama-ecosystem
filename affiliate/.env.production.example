# ============================================================
# PRODUCTION ENV TEMPLATE — AFFILIATE (affiliate.masfirmanpratama.com)
# ============================================================
# Copy ke `.env` di server produksi, lalu ISI nilai placeholder.
# JANGAN commit file .env yang sudah terisi secret.
# Generate APP_KEY dengan: php artisan key:generate
# ============================================================

APP_NAME="MasFirmanPratama Affiliate"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://affiliate.masfirmanpratama.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Asia/Jakarta

# --- Logging ---
LOG_CHANNEL=daily
LOG_LEVEL=warning

# --- Database (MySQL produksi, schema TERPISAH dari store) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=affiliate_db
DB_USERNAME=CHANGE_ME
DB_PASSWORD=*** --- Session / Cache / Queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=false
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Mail (isi SMTP produksi) ---
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE...n
# --- Webhook receiver dari Store (HMAC-SHA256) ---
# WAJIB sama persis dengan AFFILIATE_WEBHOOK_SECRET di app store.
# Kalau kosong, receiver fail-closed (tolak semua webhook dengan 503).
STORE_WEBHOOK_SECRET=CHANGE...n
# --- Admin login (single admin, dari config/.env) ---
# Cek config/admin.php untuk nama key persisnya.
ADMIN_EMAIL=CHANGE_ME
ADMIN_PASSWORD=*** 